{
    "cli": {
        "version": ">= 5.2.0",
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "env": {
                "EXPO_USE_GRADLE_DAEMON": "true"
            }
        },
        "preview": {
            "android": {
                "buildType": "apk"
            },
            "distribution": "internal",
            "env": {
                "EXPO_USE_GRADLE_DAEMON": "true"
            }
        },
        "production": {
            "android": {
                "buildType": "apk"
            },
            "env": {
                "EXPO_USE_GRADLE_DAEMON": "true"
            }
        }
    },
    "submit": {
        "production": {}
    }
}