# Appwrite Configuration
# Get these values from your Appwrite Cloud dashboard: https://cloud.appwrite.io

# Appwrite API Endpoint (default: https://cloud.appwrite.io/v1)
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# Your Appwrite Project ID
# Found in: Project Settings > General > Project ID
EXPO_PUBLIC_APPWRITE_PROJECT_ID=

# Your Appwrite Database ID
# Found in: Database > Settings > Database ID
EXPO_PUBLIC_APPWRITE_DATABASE_ID=

# Collection IDs
# Found in: Database > [Collection Name] > Settings > Collection ID
# These are the unique IDs assigned when you create collections in Appwrite
# If not provided, will default to collection names: 'accounts', 'transactions', 'monthlyPlans'
EXPO_PUBLIC_APPWRITE_COLLECTION_ACCOUNTS=
EXPO_PUBLIC_APPWRITE_COLLECTION_TRANSACTIONS=
EXPO_PUBLIC_APPWRITE_COLLECTION_MONTHLY_PLANS=
